{"id": 29463, "latest_query_data_id": null, "name": "[\ud504\ub85c\ubaa8\uc158] \uc608\uc57d&\ubaa9\ud45c\ub2ec\uc131\uc728 (\uc2e4\uc2dc\uac04)", "description": null, "query": "--24553\n\nwith campaign_gpid_list AS (\n    SELECT TRIM(gpid_value) AS gpid\n    FROM `mrtdata.business.promotion_master_sheet`,\n    UNNEST(SPLIT(REPLACE(REPLACE(gpid, '\"', ''), ' ', ''))) AS gpid_value\n    WHERE campaign_id = '{{campaign_id}}'\n    \n    UNION DISTINCT\n    SELECT TRIM(gpid_value) AS gpid\n    FROM `mrtdata.business.promotion_master_sheet_acm_searchresult`,\n    UNNEST(SPLIT(REPLACE(REPLACE(gpid, '\"', ''), ' ', ''))) AS gpid_value\n    WHERE promo_key_name = '{{campaign_id}}'\n)\n, campaign_gid_list AS (\n    SELECT TRIM(gid_value) AS gid\n    FROM `mrtdata.business.promotion_master_sheet`,\n    UNNEST(SPLIT(REPLACE(REPLACE(gid, '\"', ''), ' ', ''))) AS gid_value\n    WHERE campaign_id = '{{campaign_id}}'\n    \n    UNION DISTINCT\n    SELECT TRIM(gid_value) AS gid\n    FROM `mrtdata.business.promotion_master_sheet_acm_searchresult`,\n    UNNEST(SPLIT(REPLACE(REPLACE(gid, '\"', ''), ' ', ''))) AS gid_value\n    WHERE promo_key_name = '{{campaign_id}}'\n    \n    UNION DISTINCT \n    SELECT CAST(p.property_id AS STRING) AS gid\n    FROM `mrtdata.edw.DW_MRT_STAY_PROPERTY` AS p\n    JOIN campaign_gpid_list AS l ON CAST(p.accommodation_id AS STRING) = l.gpid\n)\n\n, sales_data as (\n    SELECT '{{campaign_id}}' as campaign_id,\n            CASE WHEN '{{trunc_by}}' = '\ub204\uc801' THEN  TIMESTAMP('1999-01-01')\n                WHEN '{{trunc_by}}' = 'HOUR' THEN TIMESTAMP_TRUNC(r.created_at, HOUR)\n                WHEN '{{trunc_by}}' = 'DAY' THEN TIMESTAMP_TRUNC(r.created_at, DAY)\n            END AS basis_hour,\n        COUNT(DISTINCT r.reservation_no) as RESVE,\n        SUM(r.sale_price) as GMV,\n        COUNT(DISTINCT r.user_id) as USER_CNT,\n        COUNT(DISTINCT CASE WHEN STATUS IN ('CONFIRM', 'FINISH') THEN r.reservation_no END) as CRESVE,\n        SUM(CASE WHEN STATUS IN ('CONFIRM', 'FINISH') THEN r.sale_price END) as CGMV,\n        COUNT(DISTINCT CASE WHEN STATUS IN ('CONFIRM', 'FINISH') THEN r.user_id END) as CUSER_CNT,\n        SUM(CASE WHEN STANDARD_CATEGORY_LV_2_CD = 'ACCOMMODATION_TICKET' then 1 ELSE DATE_DIFF(DATE(r.trip_ended_at), DATE(r.trip_started_at), DAY) END) as RN,\n        SUM(CASE WHEN STATUS IN ('CONFIRM', 'FINISH') and STANDARD_CATEGORY_LV_2_CD = 'ACCOMMODATION_TICKET' then 1 \n                 WHEN STATUS IN ('CONFIRM', 'FINISH') then DATE_DIFF(DATE(r.trip_ended_at), DATE(r.trip_started_at), DAY) END) as confirm_RN\n        \n    FROM `edw_stream.orders_mysql_orders_reservations` AS r\n    LEFT JOIN edw_mart.MART_PRODUCT_D as p ON r.product_id = p.GID\n    WHERE status NOT IN ('FAIL', 'TEMP')\n    AND DATE(r.created_at) between '{{start_date}}' and '{{end_date}}'\n    AND r.created_at >=  '{{promo_start_dt}}'\n    \n    AND r.product_id in (SELECT GID FROM campaign_gid_list)\n    GROUP BY 1, 2 \n)\n\n, basis as (\n    SELECT a.*,\n        SAFE_DIVIDE(GMV, RN) as ADR\n        , '||' as line\n         , target_rsv_cnt as t_resve\n         --, 0 as t_cresve\n         \n         , target_gmv as t_gmv\n         , target_cgmv as t_cgmv\n         \n         --, 0 as t_user_cnt\n         --, 0 as t_cuser_cnt\n         \n         , target_rn as t_rn\n         --, 0 as t_confirm_rn\n         , target_adr as t_adr\n    FROM sales_data as a \n    LEFT JOIN `mrtdata.business.promotion_gid_target_gmv` as g \n    on TRIM(LOWER(a.campaign_id)) = TRIM(LOWER(g.campaign_id))\n) \n\n, last_updated_stat as (\n    SELECT MAX(FORMAT_TIMESTAMP('%Y-%m-%d %H:%M:%S', created_at)) as last_updated_at\n    FROM `edw_stream.orders_mysql_orders_reservations` AS r\n)\n\nselect distinct a.*\n     , '||' as line\n     , safe_divide(resve,t_resve) * 100 as t_resve_rate\n     , safe_divide(gmv,t_gmv) * 100 as t_gmv_rate\n     --, safe_divide(user_cnt,t_user_cnt) * 100 as t_user_cnt_rate\n     --, safe_divide(cresve,t_cresve) * 100 as t_cresve_rate\n     , safe_divide(cgmv,t_cgmv) * 100 as t_cgmv_rate\n     --, safe_divide(CUSER_CNT,t_cuser_cnt) * 100 as t_cuser_rate\n     , safe_divide(rn,t_rn) * 100 as t_rn_rate\n     --, safe_divide(confirm_rn,t_confirm_rn) * 100 as t_confirm_rn_rate\n     , safe_divide(adr,t_adr) * 100 as t_adr_rate\n     \n     , last_updated_at\nfrom basis as a \nleft join last_updated_stat as b \non 1=1\n", "query_hash": "d2531e2c3c9ad72b0dd11dd1e98ca349", "schedule": null, "api_key": "k2k6U7OwAybJLYkWsdSmMKcs7GP5yCOXAmg8kcR8", "is_archived": false, "is_draft": false, "updated_at": "2026-03-13T10:14:18.827+09:00", "created_at": "2025-05-30T16:39:03.774+09:00", "data_source_id": 17, "options": {"apply_auto_limit": true, "parameters": [{"title": "start_date", "name": "start_date", "type": "date", "global": false, "locals": [], "value": "2025-05-12"}, {"title": "end_date", "name": "end_date", "type": "date", "global": false, "locals": [], "value": "2025-05-19"}, {"title": "trunc_by", "name": "trunc_by", "type": "enum", "global": false, "locals": [], "enumOptions": "DAY\nHOUR\n\ub204\uc801", "value": "\ub204\uc801"}, {"title": "campaign_id", "name": "campaign_id", "type": "text", "global": false, "locals": [], "value": "japan_deuktemweek_2025_prom"}, {"title": "promo_start_dt", "name": "promo_start_dt", "type": "datetime-with-seconds", "global": false, "locals": [], "value": "2025-06-02 10:00:00"}]}, "version": 1, "tags": [], "is_safe": false, "user": {"id": 471, "name": "MRT Data", "email": "data@myrealtrip.com", "profile_image_url": "https://www.gravatar.com/avatar/234b26ba967fda92ff7b455a17d07d4d?s=40&d=identicon", "groups": [13, 7, 2], "updated_at": "2026-04-02T11:09:16.197+09:00", "created_at": "2022-04-12T21:47:52.474+09:00", "disabled_at": null, "is_disabled": false, "active_at": "2026-04-02T02:08:39Z", "is_invitation_pending": false, "is_email_verified": true, "auth_type": "external"}, "last_modified_by": {"id": 408, "name": "\uc774\uc120\uc8fc", "email": "sunju.lee@myrealtrip.c